{
  "name": "FlowJudge",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/FlowJudge/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/FlowJudge",
        "browser": "apps/FlowJudge/src/main.ts",
        "tsConfig": "apps/FlowJudge/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          { "glob": "**/*", "input": "apps/FlowJudge/public" },
          { "glob": "**/*", "input": "apps/FlowJudge/src/assets", "output": "assets/"},
          { "glob": "configuration.json",         "input": "configs", "output": "." },
          { "glob": "configuration.local.json",     "input": "configs", "output": "." },
          { "glob": "configuration.docker.json",  "input": "configs", "output": "." },
          { "glob": "**/*.json",                  "input": "apps/FlowJudge/src/assets/i18n", "output": "assets/i18n" }
        ],
        "styles": [
          "apps/FlowJudge/src/styles.scss",
          "node_modules/@angular/material/prebuilt-themes/azure-blue.css"
        ]
      },
            "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/FlowJudge/src/environments/environment.ts",
              "with": "apps/FlowJudge/src/environments/environment.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/FlowJudge/src/environments/environment.ts",
              "with": "apps/FlowJudge/src/environments/environment.local.ts"
            }
          ]
        },
        "docker": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/FlowJudge/src/environments/environment.ts",
              "with": "apps/FlowJudge/src/environments/environment.docker.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "FlowJudge:build:production"
        },
        "development": {
          "buildTarget": "FlowJudge:build:development"
        }
      },
      "options": {
        "proxyConfig": "apps/FlowJudge/proxy.conf.json",
        "ssl": true,
        "sslKey": "./key.pem",
        "sslCert": "./cert.pem"
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/FlowJudge/jest.config.cts",
        "tsConfig": "apps/FlowJudge/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "FlowJudge:build",
        "staticFilePath": "dist/apps/FlowJudge/browser",
        "spa": true
      }
    }
  }
}
